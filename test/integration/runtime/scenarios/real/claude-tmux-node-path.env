# Real-smoke: verify tmux session uses absolute node path after #445 fix.
# Launches claude runtime, then checks that the tmux session's PATH contains
# the directory of process.execPath (the node binary running core).
REAL_REQUIRES=claude
RUNTIME_MODE=real
SETUP_RUNTIME=codex
SCENARIO_CMD=zylos runtime claude && node -e "const cp=require('child_process'),path=require('path');const envLine=cp.execSync('tmux show-environment -t claude-main PATH',{encoding:'utf8'}).trim();const nodeBin=path.dirname(process.execPath);if(!envLine.includes(nodeBin)){console.error('FAIL tmux PATH missing '+nodeBin+' got: '+envLine);process.exit(1)}console.log('TMUX_NODE_PATH_OK execDir='+nodeBin)"
EXPECT_EXIT=0
EXPECT_STDOUT=Switched to
EXPECT_STDOUT_2=TMUX_NODE_PATH_OK

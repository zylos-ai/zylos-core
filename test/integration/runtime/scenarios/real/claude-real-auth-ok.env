# Opt-in real smoke. Credentials are injected at runtime by run.sh real-smoke
# from real-creds.local.env or host env; do not commit secrets here.
RUNTIME_MODE=real
SCENARIO_CMD=zylos runtime claude
SETUP_RUNTIME=codex
EXPECT_EXIT=0
EXPECT_STDOUT=Checking claude authentication...
EXPECT_STDOUT_2=Switched to
EXPECT_STDERR=

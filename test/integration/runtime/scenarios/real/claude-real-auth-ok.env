# Opt-in real smoke. Credentials are injected at runtime by run.sh real-smoke
# from real-claude-auth.local.env or host env; do not commit secrets here.
# Starts on codex (SETUP_RUNTIME) so this is a real codex->claude switch.
REAL_REQUIRES=claude
RUNTIME_MODE=real
SCENARIO_CMD=zylos runtime claude
SETUP_RUNTIME=codex
EXPECT_EXIT=0
EXPECT_STDOUT=Checking claude authentication...
EXPECT_STDOUT_2=Switched to
EXPECT_STDERR=

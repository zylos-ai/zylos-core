# Opt-in real smoke for the codex runtime. Codex authenticates from
# ~/.codex/auth.json (apikey or chatgpt mode), provisioned by run.sh real-smoke
# from the gitignored real-codex-auth.local.json seed; do not commit secrets here.
# Starts on claude (SETUP_RUNTIME) so this is a real claude->codex switch — the
# mirror of claude-real-auth-ok, so the two together cover both switch directions.
REAL_REQUIRES=codex
RUNTIME_MODE=real
SCENARIO_CMD=zylos runtime codex
SETUP_RUNTIME=claude
EXPECT_EXIT=0
EXPECT_STDOUT=Checking codex authentication...
EXPECT_STDOUT_2=Switched to
EXPECT_STDERR=

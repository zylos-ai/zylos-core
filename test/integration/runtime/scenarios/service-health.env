# Proves DB-backed deployed skills resolve and load their own Node 22 native
# better-sqlite3 dependency from each skill's nested node_modules, then can open
# and use a SQLite DB. A hoisted/global better-sqlite3 must not make this pass.
SETUP=init
SCENARIO_CMD=node -e 'const fs=require("fs"),path=require("path"),{createRequire}=require("module");const skills=["scheduler","comm-bridge","web-console"];for(const skill of skills){const root=path.join(process.env.ZYLOS_DIR,".claude","skills",skill);const pkg=path.join(root,"package.json");const req=createRequire(pkg);const resolved=req.resolve("better-sqlite3");const expected=path.join(root,"node_modules","better-sqlite3")+path.sep;if(!resolved.startsWith(expected)){console.error(`BAD_RESOLVE ${skill} ${resolved}`);process.exit(1)}const Database=req("better-sqlite3");const dbPath=path.join(process.env.ZYLOS_DIR,`${skill}-service-health.db`);try{const db=new Database(dbPath);try{db.exec("CREATE TABLE smoke (id INTEGER PRIMARY KEY, name TEXT NOT NULL)");db.prepare("INSERT INTO smoke (name) VALUES (?)").run(skill);const row=db.prepare("SELECT name FROM smoke WHERE id = 1").get();if(!row||row.name!==skill){console.error(`BAD_CRUD ${skill}`);process.exit(1)}}finally{db.close()}}finally{for(const suffix of ["","-shm","-wal"])try{fs.unlinkSync(dbPath+suffix)}catch{}}console.log(`SERVICE_HEALTH_OK ${skill}`)}console.log("SERVICE_HEALTH_OK all")'
EXPECT_EXIT=0
EXPECT_STDOUT=SERVICE_HEALTH_OK all
EXPECT_STDERR=

# Proves SETUP=init yields a *usable* post-init workspace, not just a
# config-readable one. Loads the generated pm2/ecosystem.config.cjs (which
# resolves skill script paths from $HOME/zylos) and asserts every app's script
# file actually exists in the cloned workspace. This is the assertion that would
# have caught the ZYLOS_DIR-vs-$HOME/zylos layout mismatch: if the clone lands
# skills somewhere the ecosystem can't resolve, fs.existsSync fails here.
SETUP=init
SCENARIO_CMD=node -e 'const e=require(process.env.ZYLOS_DIR+"/pm2/ecosystem.config.cjs"),fs=require("fs");const miss=e.apps.filter(a=>!fs.existsSync(a.script));if(miss.length){console.error("MISSING "+miss.map(m=>m.script).join(","));process.exit(1)}console.log("ECOSYSTEM_OK apps="+e.apps.length)'
EXPECT_EXIT=0
EXPECT_STDOUT=ECOSYSTEM_OK
EXPECT_STDERR=

# Verifies that buildCleanEnv() includes dirname(execPath) in the resulting
# PATH even when processEnv.PATH contains no nvm segment — the #445 fix.
# Uses a synthetic execPath to simulate the PM2-strips-nvm scenario.
SETUP=init
SCENARIO_CMD=node --input-type=module -e 'import{buildCleanEnv}from"/repo/cli/lib/runtime/tmux-env.js";const e={PATH:"/usr/sbin:/usr/bin:/sbin:/bin",HOME:process.env.HOME,USER:process.env.USER||"test",LOGNAME:process.env.USER||"test",LANG:"en_US.UTF-8",LC_ALL:"en_US.UTF-8",TERM:"xterm-256color",SHELL:"/bin/bash"};const{env}=buildCleanEnv({processEnv:e,dotenvVars:{},platform:"linux",execPath:"/home/test/.nvm/versions/node/v22.0.0/bin/node"});const p=env.PATH.split(":");const ei=p.indexOf("/home/test/.nvm/versions/node/v22.0.0/bin");const si=p.indexOf("/usr/bin");if(ei<0){console.error("execPath dir missing from PATH: "+env.PATH);process.exit(1)}if(ei>=si){console.error("execPath dir not before /usr/bin: idx="+ei+" sysIdx="+si);process.exit(1)}console.log("EXECPATH_IN_PATH idx="+ei+" before=/usr/bin@"+si)'
EXPECT_EXIT=0
EXPECT_STDOUT=EXECPATH_IN_PATH
